{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": ["Read(./.env)", "Read(./.env.*)"],
    "ask": ["Bash(git push *)", "Bash(git commit *)", "WebFetch"],
    "allow": [
      "Bash(npx vitest *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(npm test)",
      "Bash(npm run lint)",
      "Bash(npm run coverage:check)",
      "Bash(npm ls *)"
    ]
  },
  // このプロジェクトは全てを自己責任としてください
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
